.half-padding-bottom
	%p.body-large.dark-text-color.bold-font-name.promo-header.no-margin-bottom
		Most helpful reviews
	%p.body-medium
		%img{:src=>"/images/public/testimonial-stars.svg", :width=>"96px"}
		Real reviews, real results
.row
	.col-sm-6
		.promo-testimonial.border-bottom.margin-bottom
			.promo-testimonial-header.half-margin-bottom.d-flex.justify-space-between
				.promo-testimonial-avatar
					.media
						.pull-left
							%img{:src=>"/images/public/testimonial-avatar.svg", :width=>"50px"}
						
						.media-body.text-left
							%p.body-small.no-margin-bottom.dark-text-color.bold-font-name
								Jarred T.
							%p.micro-text.no-margin-bottom.light-text-color
								PMP
				.promo-testimonial-verified
					%img.max-width{:src=>"/images/public/verified-review.svg", :width=>"100px"}
			.promo-testimonial-body
				%p.dark-text-color
					“Thank you for your help yesterday!! I ran through the simulation exam - it showed me where I needed to brush up. I took the test today and Passed!!!"
	.col-sm-6
		.promo-testimonial.border-bottom.margin-bottom
			.promo-testimonial-header.half-margin-bottom.d-flex.justify-space-between
				.promo-testimonial-avatar
					.media
						.pull-left
							%img{:src=>"/images/public/testimonial-avatar.svg", :width=>"50px"}
						
						.media-body.text-left
							%p.body-small.no-margin-bottom.dark-text-color.bold-font-name
								Sydney F.
							%p.micro-text.no-margin-bottom.light-text-color
								PMP
				.promo-testimonial-verified
					%img.max-width{:src=>"/images/public/verified-review.svg", :width=>"100px"}
			.promo-testimonial-body
				%p.dark-text-color
					"Providing this valuable online book free of charge to members. The content is insightful, well-organized, and highly beneficial."
