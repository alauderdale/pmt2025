						=partial"features-2"
					.promo-section.padding-top
						=partial"reviews"
					.promo-section.border-bottom.padding-bottom.padding-top
						=partial"guarantee"	
					.promo-section.border-bottom.padding-bottom.padding-top
						=partial"videos"
					.promo-section.border-bottom.padding-bottom.padding-top
						=partial"feature-thumbs"
					.promo-section.border-bottom.padding-bottom.padding-top
						=partial"full-description"
					.promo-section.border-bottom.padding-bottom.padding-top
						=partial"faqs"
					.promo-section.padding-bottom.padding-top
						=partial"trusted-by"
					
				.pg-col.pg-buy-block.buy-block-container{:style=>"top:-300px; margin-bottom -300px;"}
