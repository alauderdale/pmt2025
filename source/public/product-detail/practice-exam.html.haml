%section.invert-section.invert-darker.product-header#product-hero
	.container
		.product-grid
			.pg-row
				.pg-col.pg-content
					%p.body-large.bold-font-name.quarter-margin-bottom.light-accent-text-color
						Program Management Professional (PgMP)® Practice Exams
					%h1.bold-font-name.half-margin-bottom.hidden-sm.hidden-xs
						Professional PgMP Practice Exams
					%p.no-margin-bottom
